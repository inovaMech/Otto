      <origin xyz="0.0179 0.0 -0.031" rpy="0.0 0.0 0.0" />
      <parent link="RightLeg_1" />
      <child link="FootRight_1" />
      <axis xyz="1.0 0.0 0.0" />
      <limit upper="1.5707963267948966" lower="-1.5707963267948966" effort="100.0" velocity="100.0" />
   </joint>

   <joint name="foot_left_joint" type="revolute">
      <origin xyz="0.0175 0.0 -0.031" rpy="0.0 0.0 0.0" />
      <parent link="LeftLeg_1" />
      <child link="FootLeft_1" />
      <axis xyz="1.0 0.0 0.0" />
      <limit upper="1.5707963267948966" lower="-1.5707963267948966" effort="100.0" velocity="100.0" />
   </joint>

   <!-- ==================== GAZEBO PLUGINS ==================== -->
   <!--
      PID ajustado para massas x10:
        P: subiu de 1 -> 10  (torque proporcional à massa)
        D: subiu de 1 -> 0.5 (amortecimento — menor que P para nao oscilar)
        I: mantido em 0 (evita windup em juntas de baixa fricçao)
      Ponto de partida conservador; ajuste fino experimental:
        se oscilar -> reduza P para 7-8
        se lento/mole -> aumente P para 12-15
        se trepida -> aumente D para 0.8-1.0
   -->
   <gazebo>
      <plugin filename="gz-sim-joint-position-controller-system"
               name="gz::sim::systems::JointPositionController">
         <joint_name>leg_right_joint</joint_name>
         <topic>/leg_right_joint/cmd</topic>
         <p_gain>10.0</p_gain>
         <i_gain>0.0</i_gain>
         <d_gain>0.5</d_gain>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
               name="gz::sim::systems::JointPositionController">
         <joint_name>leg_left_joint</joint_name>
         <topic>/leg_left_joint/cmd</topic>
         <p_gain>10.0</p_gain>
         <i_gain>0.0</i_gain>
         <d_gain>0.5</d_gain>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
               name="gz::sim::systems::JointPositionController">
         <joint_name>foot_right_joint</joint_name>
         <topic>/foot_right_joint/cmd</topic>
         <p_gain>10.0</p_gain>
         <i_gain>0.0</i_gain>
         <d_gain>0.5</d_gain>
      </plugin>
      <plugin filename="gz-sim-joint-position-controller-system"
               name="gz::sim::systems::JointPositionController">
         <joint_name>foot_left_joint</joint_name>
         <topic>/foot_left_joint/cmd</topic>
         <p_gain>10.0</p_gain>
         <i_gain>0.0</i_gain>
         <d_gain>0.5</d_gain>
      </plugin>
   </gazebo>

   <!-- ==================== CONTATO/FRICTION PES ==================== -->
   <gazebo reference="FootRight_1">
      <surface>
         <friction>
            <ode>
               <mu>0.8</mu>
               <mu2>0.8</mu2>
            </ode>
         </friction>
         <contact>
            <ode>
               <kp>1e5</kp>
               <kd>1.0</kd>
               <min_depth>0.001</min_depth>
            </ode>
         </contact>
      </surface>
   </gazebo>

   <gazebo reference="FootLeft_1">
      <surface>
         <friction>
            <ode>
               <mu>0.8</mu>
               <mu2>0.8</mu2>
            </ode>
         </friction>
         <contact>
            <ode>
               <kp>1e5</kp>
               <kd>1.0</kd>
               <min_depth>0.001</min_depth>
            </ode>
         </contact>
      </surface>
   </gazebo>
   

</robot>
