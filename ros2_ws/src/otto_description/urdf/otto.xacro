<?xml version='1.0' encoding='utf-8'?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="otto">
   <xacro:include filename="$(find otto)/urdf/materials.xacro" />

   <!-- ==================== LINKS ==================== -->

   <!--
      base_footprint: link raiz fictício posicionado no chao (z=0).
      Sem massa nem inercia — serve apenas como referência estável para o Gazebo.
      O base_link fica 0.08 m acima do chao (altura real do corpo do Otto).
   -->
   <link name="base_footprint" />

   <joint name="base_footprint_joint" type="fixed">
      <origin xyz="0.0 0.0 0.08" rpy="0.0 0.0 0.0" />
      <parent link="base_footprint" />
      <child link="base_link" />
   </joint>

   <!--
      MASSAS ESCALADAS PARA ESTABILIDADE NUMERICA DO GAZEBO
      ===================================================
      Fator aplicado por grupo (mantendo razoes relativas do CAD real):
        base_link, pernas, cabeca  -> x10
        pes (contato crítico)      -> x12
        ultrasonico               -> x5
      Total simulado: ~1.26 kg  (original CAD: ~143 g)
      Inercias escaladas pelo mesmo fator (I proporcional a m).
      Todos os tensores passam na condiçao de Sylvester (ixx < iyy+izz, etc).
   -->

   <link name="base_link">
      <inertial>
         <origin xyz="-0.017480908878091606 0.03519882134873651 -0.025083002755304264" rpy="0.0 0.0 0.0" />
         <!-- original: 0.03208 kg  ->  x10 = 0.3208 kg -->
         <mass value="0.3208" />
         <inertia ixx="2.49503e-04" iyy="2.55347e-04" izz="4.05347e-04"
                  ixy="1.7290e-06"  iyz="7.21e-07"    ixz="-2.471e-06" />
      </inertial>
      <visual>
         <origin xyz="0.0 0.0 -0.09000000000000001" rpy="0.0 0.0 0.0" />
         <geometry>
            <mesh filename="package://otto/meshes/base_link_1.stl" scale="0.001 0.001 0.001" />
         </geometry>
         <material name="ABS{Branco}" />
      </visual>
      <collision>
         <origin xyz="0.0 0.0 -0.09000000000000001" rpy="0.0 0.0 0.0" />
         <geometry>
            <mesh filename="package://otto/meshes/base_link_1.stl" scale="0.001 0.001 0.001" />
         </geometry>
      </collision>
   </link>

