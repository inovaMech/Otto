   <!-- ==================== JOINTS ==================== -->

   <joint name="leg_right_joint" type="revolute">
      <origin xyz="-0.012391174437753782 0.005158205912836682 -0.039" rpy="0.0 0.0 0.0" />
      <parent link="base_link" />
      <child link="RightLeg_1" />
      <axis xyz="0.0 0.0 1.0" />
      <limit upper="1.5707963267948966" lower="-1.5707963267948966" effort="100.0" velocity="100.0" />
   </joint>

   <joint name="leg_left_joint" type="revolute">
      <origin xyz="-0.016999572875253794 0.061000427124746216 -0.037000000000000005" rpy="0.0 0.0 0.0" />
      <parent link="base_link" />
      <child link="LeftLeg_1" />
      <axis xyz="0.0 0.0 -1.0" />
      <limit upper="1.5707963267948966" lower="-1.5707963267948966" effort="100.0" velocity="100.0" />
   </joint>

   <joint name="ultrasonic_joint" type="fixed">
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0" />
      <parent link="base_link" />
      <child link="Ultrasonic_Sensor_v1_1_1" />
   </joint>

   <joint name="head_joint" type="fixed">
      <origin xyz="0.00011642897127504436 6.011660760218973e-07 -0.0009665825749333657" rpy="0.0 0.0 0.0" />
      <parent link="base_link" />
      <child link="Head_1_1" />
   </joint>

