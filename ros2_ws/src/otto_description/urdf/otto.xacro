         <!-- link fixo: massa simbólica -->
         <mass value="0.024" />
         <inertia ixx="1.64375e-05" iyy="1.56695e-05" izz="2.6288e-05"
                  ixy="2.718e-07"   iyz="8.04e-08"     ixz="9.08e-08" />
