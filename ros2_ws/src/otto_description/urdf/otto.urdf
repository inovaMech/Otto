  <!-- ==================== JOINTS ==================== -->

  <joint name="LeftLeg" type="revolute">
    <parent link="base_link"/>
    <child link="leg_left"/>
    <origin xyz="-0.026 0.0 0.039" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="1.5" velocity="3.14"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <joint name="RightLeg" type="revolute">
    <parent link="base_link"/>
    <child link="leg_right"/>
    <origin xyz="0.026 0.0 0.039" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="1.5" velocity="3.14"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <joint name="LeftFoot" type="revolute">
    <parent link="leg_left"/>
    <child link="foot_left"/>
    <origin xyz="0.0 0.02 0.031" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="1.5" velocity="3.14"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <joint name="RightFoot" type="revolute">
    <parent link="leg_right"/>
    <child link="foot_right"/>
    <origin xyz="0.0 0.0185 0.031" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="1.5" velocity="3.14"/>
    <dynamics damping="0.01" friction="0.0"/>
  </joint>

  <joint name="head_joint" type="fixed">
    <parent link="base_link"/>
    <child link="head"/>
    <origin xyz="0.033 0.0 -0.007" rpy="3.14159 0 0"/>
  </joint>

  <joint name="ultrasonic_joint" type="fixed">
    <parent link="head"/>
    <child link="ultrasonic"/>
    <origin xyz="0.013675 -0.0327 0.0175" rpy="0 0 0"/>
  </joint>

</robot>
