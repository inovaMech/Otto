    <collision>
      <surface>
        <friction>
          <ode><mu>0.8</mu><mu2>0.8</mu2></ode>
        </friction>
        <contact>
          <ode><kp>5e4</kp><kd>10.0</kd><min_depth>0.001</min_depth></ode>
        </contact>
      </surface>
    </collision>
  </gazebo>
  <gazebo reference="FootLeft_1">
